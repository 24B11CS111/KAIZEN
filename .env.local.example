# KAIZEN.SYS — Environment Variables
# Copy this file to .env.local and fill in your real values.
# After saving, RESTART `npm run dev` (Next.js only reads env at startup).
#
# All NEXT_PUBLIC_* vars are exposed to the browser.
# SUPABASE_SERVICE_ROLE_KEY must NEVER be prefixed with NEXT_PUBLIC_.
#
# See PRODUCTION_SETUP.md for full Supabase production auth configuration.

# --- Required: Supabase (Supabase Dashboard → Project → Settings → API) ---
# URL format: https://[project-ref].supabase.co (no trailing path!)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-service-role-key

# --- Required: Canonical site URL for auth redirects ---
# Set this in Vercel Dashboard → Project → Settings → Environment Variables.
# Must be your PRODUCTION domain (no trailing slash).
# Supabase GoTrue validates redirectTo URLs against this.
# Also add to Supabase Dashboard → Auth → URL Configuration → Redirect URLs:
#   https://your-domain.vercel.app/auth/callback?*
#   https://*.vercel.app/auth/callback?*    (covers preview deploys)
#   http://localhost:3000/auth/callback?*   (local dev)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# --- Required: Admin gate (who can access /admin and /sensei) ---
ADMIN_EMAIL=your-admin@email.com

# --- Optional: UPI payment display ---
NEXT_PUBLIC_UPI_ID=kaizen@upi
NEXT_PUBLIC_UPI_NAME=KAIZEN
NEXT_PUBLIC_UPI_QR_PATH=https://res.cloudinary.com/dzqfrwizz/image/upload/v1778002547/70f7bcee-4a22-41ea-b6c9-5af680bfc6a0_fjcl52.png

# --- Optional: rate limiting (defaults applied if unset) ---
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=3600000

# --- Optional: Spline 3D scene URL ---
NEXT_PUBLIC_SPLINE_SCENE=

# --- Dev: bypass auth gates (NEVER set to 1 in production) ---
NEXT_PUBLIC_BYPASS_AUTH=0
